---
import { link } from '../utils/link';

const path = Astro.url.pathname;

const navItems = [
  { href: link('/process'), label: 'Process', n: '02' },
  { href: link('/cases'), label: 'City projects', n: '03' },
  { href: link('/research'), label: 'Research', n: '04' },
  { href: link('/foundation'), label: 'Foundation', n: '05' },
];
---

<header class="uc-header">
  <div class="uc-shell uc-header-inner">
    <a href={link('/')} class="uc-header-brand" aria-label="Unlimited Cities — home">
      <span class="uc-mono uc-header-mono">N° 01</span>
      <span class="uc-header-name">Unlimited&nbsp;Cities</span>
    </a>

    {/* Desktop nav */}
    <nav class="uc-header-nav" aria-label="Primary">
      {
        navItems.map((item) => {
          const active = path === item.href || path.startsWith(item.href + '/');
          return (
            <a href={item.href} class:list={['uc-header-link', { active }]}>
              <span class="uc-mono uc-header-link-num">N° {item.n}</span>
              <span class="uc-header-link-label">{item.label}</span>
            </a>
          );
        })
      }
    </nav>

    {/* Mobile hamburger */}
    <button class="uc-header-burger" aria-label="Open menu" aria-controls="uc-mobile-menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
  <hr class="uc-rule" />
</header>

{/* Mobile menu overlay — sibling of <header> so position: fixed escapes
    the header's backdrop-filter containing block. */}
<div id="uc-mobile-menu" class="uc-mobile-menu" aria-hidden="true">
  <nav class="uc-mobile-menu-inner" aria-label="Mobile primary">
    {
      navItems.map((item) => {
        const active = path === item.href || path.startsWith(item.href + '/');
        return (
          <a href={item.href} class:list={['uc-mobile-link', { active }]}>
            <span class="uc-mono uc-mobile-link-num">N° {item.n}</span>
            <span class="uc-mobile-link-label">{item.label}</span>
          </a>
        );
      })
    }
    <div class="uc-mobile-menu-foot">
      <p class="uc-mono">Open Urbanism Foundation</p>
      <p class="uc-mono">Geneva, Switzerland</p>
    </div>
  </nav>
</div>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.uc-header-burger');
  const menu = document.querySelector<HTMLElement>('#uc-mobile-menu');
  const html = document.documentElement;

  function setOpen(open: boolean) {
    if (!burger || !menu) return;
    burger.setAttribute('aria-expanded', String(open));
    burger.classList.toggle('is-open', open);
    menu.setAttribute('aria-hidden', String(!open));
    menu.classList.toggle('is-open', open);
    html.classList.toggle('uc-no-scroll', open);
  }

  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    setOpen(!open);
  });

  // Close on link click
  document.querySelectorAll('.uc-mobile-link').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>

<style>
  .uc-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-uc-paper) 94%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .uc-header-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    padding-bottom: 1rem;
  }

  .uc-header-brand {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    line-height: 1;
  }

  .uc-header-mono { font-size: 0.7rem; }

  .uc-header-name {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-uc-ink);
  }

  /* ─── Desktop nav ─── */
  .uc-header-nav {
    display: flex;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: flex-end;
  }

  .uc-header-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    line-height: 1;
    padding: 0.25rem 0;
    color: var(--color-uc-ink);
    transition: opacity 0.2s;
  }

  .uc-header-link:hover { opacity: 0.55; }

  .uc-header-link-num { font-size: 0.7rem; }

  .uc-header-link-label {
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .uc-header-link.active .uc-header-link-label { font-weight: 600; }

  /* ─── Burger button (mobile only) ─── */
  .uc-header-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .uc-header-burger span {
    display: block;
    height: 1.5px;
    width: 22px;
    background: var(--color-uc-ink);
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .uc-header-burger.is-open span:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }
  .uc-header-burger.is-open span:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ─── Mobile menu overlay ─── */
  .uc-mobile-menu {
    position: fixed;
    inset: 0;
    top: 0;
    background: var(--color-uc-paper);
    z-index: 49;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 6rem clamp(1.5rem, 4vw, 4rem) 2rem;
    transform: translateY(-100%);
    transition: transform 0.4s cubic-bezier(0.76, 0, 0.24, 1);
    visibility: hidden;
  }

  .uc-mobile-menu.is-open {
    transform: translateY(0);
    visibility: visible;
  }

  .uc-mobile-menu-inner {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-uc-line);
  }

  .uc-mobile-link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    color: var(--color-uc-ink);
    padding: 0.35rem 0;
    border-bottom: 1px solid transparent;
    transition: opacity 0.15s;
  }

  .uc-mobile-link:hover { opacity: 0.55; }

  .uc-mobile-link-num {
    font-size: 0.75rem;
    flex-shrink: 0;
    width: 3rem;
  }

  .uc-mobile-link-label {
    font-size: clamp(2rem, 7vw, 2.5rem);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .uc-mobile-link.active .uc-mobile-link-label {
    font-weight: 600;
  }

  .uc-mobile-menu-foot {
    margin-top: auto;
    padding-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  /* ─── Responsive switch ─── */
  @media (max-width: 760px) {
    .uc-header-nav { display: none; }
    .uc-header-burger { display: flex; }
    .uc-header-mono { display: none; }
  }

  :global(.uc-no-scroll) { overflow: hidden; }
</style>
